#!/bin/bash
set -e

echo "🚀 Starting Tekki API..."

# Debug info
echo "🔍 Database check info:"
echo "   DATABASE_URL: ${DATABASE_URL:+(set)}"
echo "   DB_PROD: ${DB_PROD:+(set)}"
echo "   DATABASE_HOST: ${DATABASE_HOST:-db (default)}"

# Remove a potentially pre-existing server.pid for Rails.
rm -f /app/tmp/pids/server.pid

# Wait for database to be ready
if [ -z "$SKIP_DATABASE_CHECK" ]; then
  echo "🔍 Checking database connection..."
  MAX_RETRIES=15
  RETRY_COUNT=0
  
  if [ -n "$DATABASE_URL" ]; then
    until pg_isready -d "$DATABASE_URL" || [ $RETRY_COUNT -eq $MAX_RETRIES ]; do
      echo "⏳ Waiting for Database (via DATABASE_URL)... ($RETRY_COUNT/$MAX_RETRIES)"
      sleep 2
      RETRY_COUNT=$((RETRY_COUNT + 1))
    done
  else
    until pg_isready -h "${DATABASE_HOST:-db}" -p "${DATABASE_PORT:-5432}" -U "${DATABASE_USERNAME:-postgres}" || [ $RETRY_COUNT -eq $MAX_RETRIES ]; do
      echo "⏳ Waiting for Database to be available... ($RETRY_COUNT/$MAX_RETRIES)"
      sleep 2
      RETRY_COUNT=$((RETRY_COUNT + 1))
    done
  fi
  
  if [ $RETRY_COUNT -eq $MAX_RETRIES ]; then
    echo "⚠️ Database check reached timeout. Proceeding anyway..."
  else
    echo "✅ Database connection established"
  fi
fi

# Run migrations if needed (usually handled by fly.toml release_command, but kept for Kamal/Local)
if [ "$RUN_MIGRATIONS" = "true" ]; then
  echo "🔄 Running database migrations..."
  bundle exec rails db:migrate
  echo "✅ Database migrations completed"
fi

# Create necessary directories
mkdir -p /app/tmp/pids
mkdir -p /app/log

echo "🎯 Starting Rails server..."

# Then exec the container's main process
exec "$@"
